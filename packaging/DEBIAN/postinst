#!/bin/bash
# Runs as root after package files are placed on disk.
set -e

INSTALL_DIR="/opt/screen-share-tab"
VENV="$INSTALL_DIR/.venv"

echo "Setting up screen-share-tab..."

# ── Python venv + packages ────────────────────────────────────────────────────
python3 -m venv "$VENV"
"$VENV/bin/pip" install --quiet --upgrade pip
"$VENV/bin/pip" install --quiet websockets qrcode zeroconf

# ── Browser assets (served locally to the tablet — no internet at runtime) ────
# /opt is root-owned, so start.sh can't download these at runtime; fetch here.
fetch() {  # $1 = filename, $2 = url
    [ -f "$INSTALL_DIR/$1" ] && return 0
    echo "  Downloading $1..."
    curl -sL "$2" -o "$INSTALL_DIR/$1" || \
        echo "  Warning: could not download $1 (needs internet)."
}
fetch mpegts.min.js       "https://cdn.jsdelivr.net/npm/mpegts.js@1.7.3/dist/mpegts.min.js"
fetch xterm.js            "https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/lib/xterm.js"
fetch xterm.css           "https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.css"
fetch xterm-addon-fit.js  "https://cdn.jsdelivr.net/npm/@xterm/addon-fit@0.10.0/lib/addon-fit.js"

# ── Permissions — readable and executable by all users ───────────────────────
chmod -R a+rX "$INSTALL_DIR"
chmod +x "$INSTALL_DIR/start.sh"
chmod +x "$INSTALL_DIR/install-service.sh"

echo "Done. Run 'screen-share-tab' in any terminal."
